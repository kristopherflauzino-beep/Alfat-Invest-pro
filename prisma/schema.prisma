generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String
  type      String
  market    String
  sector    String
  segment   String
  currency  String   @default("BRL")
  price     Float
  source    String   @default("local")
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPortfolio {
  id           String    @id @default(cuid())
  userId       String
  ticker       String
  quantity     Float
  averagePrice Float
  broker       String?
  purchaseDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FavoriteAsset {
  id        String   @id @default(cuid())
  userId    String
  ticker    String
  createdAt DateTime @default(now())

  @@unique([userId, ticker])
}

model AlertRule {
  id          String   @id @default(cuid())
  userId      String
  ticker      String
  type        String
  targetValue Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AppUser {
  id              String    @id @default(cuid())
  role            String
  username        String    @unique
  email           String    @unique
  name            String
  phone           String?
  passwordHash    String
  planId          String?
  planValue       Float?
  status          String    @default("ativo")
  dueDate         DateTime?
  notes           String?
  permissions     Json
  emailVerifiedAt DateTime?
  nameChangeCount Int       @default(0)
  nameChangedAt   DateTime?
  emailChangedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payments Payment[]
}

model AccessPlan {
  id           String   @id
  name         String
  value        Float
  durationDays Int
  status       String   @default("ativo")
  permissions  Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Payment {
  id          String   @id @default(cuid())
  clientId    String
  client      AppUser  @relation(fields: [clientId], references: [id])
  planId      String
  value       Float
  paymentDate DateTime
  dueDate     DateTime
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PersistentAppState {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AppSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  userAgent  String?
  ipHash     String?
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model OnlinePayment {
  id                    String    @id
  userId                String
  planId                String
  subscriptionId        String?
  provider              String
  providerPaymentId     String?
  providerCheckoutId    String?
  providerEventId       String?
  method                String
  originalAmountInCents Int
  discountInCents       Int       @default(0)
  amountInCents         Int
  currency              String    @default("BRL")
  status                String    @default("pending")
  pixQrCode             String?
  pixQrCodeBase64       String?
  pixCopyPaste          String?
  pixTicketUrl          String?
  pixExpiresAt          DateTime?
  cardBrand             String?
  cardLastFour          String?
  installments          Int?
  paidAt                DateTime?
  expiresAt             DateTime?
  refundedAmountInCents Int       @default(0)
  idempotencyKey        String    @unique
  renewalMode           String    @default("extend")
  providerPayload       Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([provider, providerPaymentId])
  @@index([status])
}

model OnlineSubscription {
  id                     String    @id
  userId                 String    @unique
  planId                 String
  provider               String
  providerSubscriptionId String?
  paymentMethod          String
  planName               String
  planPriceInCents       Int
  durationDays           Int
  status                 String    @default("pending")
  startedAt              DateTime?
  expiresAt              DateTime?
  nextBillingAt          DateTime?
  cancelledAt            DateTime?
  autoRenew              Boolean   @default(false)
  cardBrand              String?
  cardLastFour           String?
  graceUntil             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([provider, providerSubscriptionId])
  @@index([status])
}

model PaymentWebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  resourceId      String?
  payloadHash     String
  processedAt     DateTime?
  status          String    @default("received")
  createdAt       DateTime  @default(now())

  @@unique([provider, providerEventId])
}

model PaymentAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  actorId   String?
  action    String
  entityId  String?
  details   Json?
  risk      String   @default("medium")
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
}

model EmailChangeToken {
  id          String    @id @default(cuid())
  userId      String
  newEmail    String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedAt DateTime
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model EmailDelivery {
  id                String    @id
  userId            String?
  recipient         String
  recipientMasked   String
  type              String
  subject           String
  status            String
  provider          String
  providerMessageId String?
  attempts          Int       @default(0)
  lastAttemptAt     DateTime?
  sentAt            DateTime?
  errorCode         String?
  errorMessage      String?
  idempotencyKey    String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, createdAt])
}

model PendingRegistration {
  id                     String    @id
  name                   String
  username               String
  email                  String
  phone                  String?
  passwordHash           String
  emailVerifiedAt        DateTime?
  continuationTokenHash  String?   @unique
  acceptedTermsAt        DateTime
  acceptedPrivacyAt      DateTime
  acceptedMarketingAt    DateTime?
  planId                 String
  planName               String
  planPriceInCents       Int
  durationDays           Int
  permissions            Json
  status                 String
  paymentProvider        String    @default("mercado_pago")
  paymentLinkOpenedAt    DateTime?
  paymentReportedAt      DateTime?
  paymentConfirmedAt     DateTime?
  paymentName            String?
  approximatePaymentDate DateTime?
  transactionId          String?
  customerNote           String?
  paymentNotes           String?
  adminNote              String?
  confirmedByUserId      String?
  activatedAt            DateTime?
  rejectedAt             DateTime?
  cancelledAt            DateTime?
  expiresAt              DateTime
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([email, status])
  @@index([username, status])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id                    String    @id
  pendingRegistrationId String
  tokenHash             String    @unique
  expiresAt             DateTime
  usedAt                DateTime?
  requestedAt           DateTime
  createdAt             DateTime  @default(now())

  @@index([pendingRegistrationId, createdAt])
  @@index([expiresAt])
}
